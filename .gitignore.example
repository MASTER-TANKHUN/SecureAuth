# Example .gitignore for this project
# Copy or adapt these entries into your real `.gitignore`
# so secrets, local databases, and generated files are not pushed to GitHub.

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local database and SQLite sidecar files
auth.db
auth.db-shm
auth.db-wal

# Logs
*.log
security.log

# Private environment files
.env
.env.local
.env.production

# Operating system files
.DS_Store
Thumbs.db

# Editor / IDE files
.vscode/
.idea/
*.swp
*.swo
