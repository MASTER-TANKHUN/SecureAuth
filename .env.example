# ============================================
# Secure Auth System - Environment Variables
# ============================================

# Server
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=change-this-to-a-very-long-random-secret-key-at-least-64-chars
ENCRYPTION_KEY=change-this-to-a-random-64-char-hex-secret
CSRF_SECRET=change-this-to-a-random-64-char-hex-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Argon2 Configuration
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# Email Configuration (use Ethereal for development)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your-ethereal-user@ethereal.email
SMTP_PASS=your-ethereal-password
EMAIL_FROM=noreply@secureauth.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_ATTEMPTS=5

# App URL
APP_URL=http://localhost:3000
